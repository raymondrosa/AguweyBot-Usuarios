# Crear archivo .gitignore
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.env
.venv

# Streamlit
.streamlit/secrets.toml
.streamlit/config.toml

# Datos de usuarios
user_data/
!user_data/.gitkeep

# Conversaciones locales
conversaciones_guardadas/

# Archivos temporales
*.tmp
*.log
.DS_Store
*.mp3
*.wav

# IDE
.vscode/
.idea/
*.swp
*.swo

# Cache
.cache/
*.pyc
EOF
